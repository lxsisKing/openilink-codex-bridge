PORT=3000
OPENILINK_WS_URL_DEFAULT=ws://127.0.0.1:9800/api/v1/channels/connect?key=REPLACE_ME
OPENILINK_WS_URL_CODEX=ws://127.0.0.1:9800/api/v1/channels/connect?key=REPLACE_ME
OPENILINK_WS_URL_REVIEW=ws://127.0.0.1:9800/api/v1/channels/connect?key=REPLACE_ME
OPENILINK_WS_URL_CHAT=ws://127.0.0.1:9800/api/v1/channels/connect?key=REPLACE_ME
CODEX_BIN=codex
CODEX_ARGS=exec --skip-git-repo-check
CODEX_MODEL=gpt-5.4
CODEX_WORKDIR=/root/projects
ALLOWED_SENDERS=
SESSION_TTL_MS=21600000
SESSION_CLEANUP_INTERVAL_MS=300000
ASR_ENABLED=true
ASR_PYTHON_BIN=/root/projects/openilink-codex-bridge/.venv-asr/bin/python
ASR_DECODE_SCRIPT=/root/projects/openilink-codex-bridge/scripts/decode_silk.py
ASR_WHISPER_BIN=/root/projects/openilink-codex-bridge/.venv-asr/bin/python
ASR_TRANSCRIBE_SCRIPT=/root/projects/openilink-codex-bridge/scripts/transcribe_wav.py
ASR_MODEL=base
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=24000
